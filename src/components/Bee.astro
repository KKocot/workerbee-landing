---
// Decorative 3D-style bee that floats over the hero section and gently
// reacts to the cursor. Movement is strictly 2D (translate + slight tilt).
---

<div id="hero-bee" class="hero-bee" aria-hidden="true">
  <div class="hero-bee__drift">
    <div class="hero-bee__float">
      <svg
        class="hero-bee__svg"
        viewBox="0 0 240 200"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Animated bee mascot"
      >
        <defs>
          <radialGradient id="beeBody" cx="38%" cy="30%" r="80%">
            <stop offset="0%" stop-color="#FDE68A" />
            <stop offset="45%" stop-color="#F59E0B" />
            <stop offset="100%" stop-color="#B45309" />
          </radialGradient>
          <radialGradient id="beeHead" cx="35%" cy="28%" r="85%">
            <stop offset="0%" stop-color="#FDE68A" />
            <stop offset="55%" stop-color="#F59E0B" />
            <stop offset="100%" stop-color="#A85B07" />
          </radialGradient>
          <linearGradient id="beeStripe" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#27262B" />
            <stop offset="100%" stop-color="#0B0B0D" />
          </linearGradient>
          <linearGradient id="beeWing" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.55" />
            <stop offset="60%" stop-color="#FDE68A" stop-opacity="0.22" />
            <stop offset="100%" stop-color="#F59E0B" stop-opacity="0.10" />
          </linearGradient>
          <filter id="beeShadow" x="-40%" y="-40%" width="180%" height="180%">
            <feDropShadow dx="0" dy="6" stdDeviation="7" flood-color="#000000" flood-opacity="0.45" />
          </filter>
          <clipPath id="beeBodyClip">
            <ellipse cx="106" cy="116" rx="72" ry="50" />
          </clipPath>
        </defs>

        <!-- Wings (behind body) -->
        <g class="hero-bee__wing hero-bee__wing--back">
          <ellipse cx="92" cy="58" rx="40" ry="24" fill="url(#beeWing)"
            stroke="#FFFFFF" stroke-opacity="0.25" stroke-width="1.5" />
        </g>
        <g class="hero-bee__wing hero-bee__wing--front">
          <ellipse cx="128" cy="52" rx="46" ry="27" fill="url(#beeWing)"
            stroke="#FFFFFF" stroke-opacity="0.3" stroke-width="1.5" />
        </g>

        <!-- Legs -->
        <g stroke="#161518" stroke-width="5" stroke-linecap="round" fill="none">
          <path d="M86 158 q-6 18 -16 24" />
          <path d="M112 162 q0 20 -4 28" />
          <path d="M138 158 q8 18 16 22" />
        </g>

        <!-- Stinger -->
        <path d="M36 116 l-22 -6 l22 -6 z" fill="#161518" />

        <!-- Body -->
        <ellipse cx="106" cy="116" rx="72" ry="50" fill="url(#beeBody)" filter="url(#beeShadow)" />

        <!-- Stripes (clipped to body) -->
        <g clip-path="url(#beeBodyClip)">
          <rect x="48" y="64" width="22" height="104" rx="6" fill="url(#beeStripe)" />
          <rect x="88" y="64" width="24" height="104" rx="6" fill="url(#beeStripe)" />
          <rect x="130" y="64" width="22" height="104" rx="6" fill="url(#beeStripe)" />
          <!-- soft top highlight for 3D volume -->
          <ellipse cx="92" cy="92" rx="58" ry="26" fill="#FFFFFF" opacity="0.16" />
        </g>

        <!-- Head -->
        <circle cx="182" cy="98" r="36" fill="url(#beeHead)" filter="url(#beeShadow)" />

        <!-- Antennae -->
        <g stroke="#161518" stroke-width="4.5" stroke-linecap="round" fill="none">
          <path d="M186 66 q6 -22 24 -30" />
          <path d="M170 66 q-2 -24 -16 -34" />
        </g>
        <circle cx="211" cy="35" r="5.5" fill="#161518" />
        <circle cx="153" cy="31" r="5.5" fill="#161518" />

        <!-- Eyes -->
        <g class="hero-bee__eyes">
          <ellipse cx="176" cy="96" rx="13" ry="15" fill="#FBFBFD" />
          <ellipse cx="198" cy="94" rx="11" ry="13" fill="#FBFBFD" />
          <circle class="hero-bee__pupil" cx="178" cy="98" r="6" fill="#161518" />
          <circle class="hero-bee__pupil" cx="199" cy="96" r="5" fill="#161518" />
          <circle cx="176" cy="95" r="2" fill="#FFFFFF" />
          <circle cx="197" cy="93" r="1.8" fill="#FFFFFF" />
        </g>

        <!-- Smile -->
        <path d="M170 118 q12 12 26 4" stroke="#161518" stroke-width="3.5"
          stroke-linecap="round" fill="none" />
      </svg>
    </div>
  </div>
</div>

<script>
  // Free-flying bee — wanders along an easing path across the hero section.
  // Strictly 2D: translate + a slight tilt + horizontal flip to face travel.
  const bee = document.getElementById("hero-bee");
  const drift = bee?.querySelector<HTMLElement>(".hero-bee__drift");
  const hero = document.getElementById("hero");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (bee && drift && hero && !reduce.matches) {
    let x = 0,
      y = 0, // current top-left position within the hero
      tx = 0,
      ty = 0, // current flight target
      face = 1, // 1 = facing right, -1 = facing left
      boundsW = 0,
      boundsH = 0;

    const clamp = (v: number, lo: number, hi: number) =>
      Math.max(lo, Math.min(hi, v));

    const measure = () => {
      boundsW = Math.max(0, hero.clientWidth - bee.offsetWidth);
      boundsH = Math.max(0, hero.clientHeight - bee.offsetHeight);
      x = clamp(x, 0, boundsW);
      y = clamp(y, 0, boundsH);
    };

    const pickTarget = () => {
      tx = Math.random() * boundsW;
      ty = Math.random() * boundsH;
    };

    const tick = () => {
      const dx = tx - x;
      const dy = ty - y;
      if (Math.hypot(dx, dy) < 14) pickTarget();

      const ease = 0.018; // lower = more graceful, slower flight
      const nx = x + dx * ease;
      const ny = y + dy * ease;
      const vx = nx - x;
      const vy = ny - y;
      x = nx;
      y = ny;

      if (vx > 0.06) face = 1;
      else if (vx < -0.06) face = -1;

      // gentle pitch: nose follows vertical travel, corrected for facing
      const tilt = clamp(vy * 7 * face, -16, 16);

      drift.style.setProperty("--bee-x", x.toFixed(1) + "px");
      drift.style.setProperty("--bee-y", y.toFixed(1) + "px");
      drift.style.setProperty("--bee-tilt", tilt.toFixed(1) + "deg");
      drift.style.setProperty("--bee-face", String(face));

      requestAnimationFrame(tick);
    };

    measure();
    x = boundsW * 0.7;
    y = boundsH * 0.3;
    pickTarget();
    window.addEventListener("resize", measure, { passive: true });
    requestAnimationFrame(tick);
  }
</script>
