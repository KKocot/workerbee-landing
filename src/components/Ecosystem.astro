---
// Ecosystem section - 3 cards for Hive ecosystem libraries
const ecosystemItems = [
  {
    letter: "W",
    name: "WAX",
    pkg: "@hiveio/wax",
    description: "Chain wrapper providing types, operation builders, and blockchain API access.",
    link: "https://github.com/openhive-network/wax",
  },
  {
    letter: "B",
    name: "Beekeeper",
    pkg: "@hiveio/beekeeper",
    description: "Secure key management and data access layer for wallet operations.",
    link: "https://github.com/openhive-network/hive/tree/develop/programs/beekeeper",
  },
  {
    letter: "$",
    name: "Balance Tracker",
    pkg: "@hiveio/wax-api-balance-tracker",
    description: "Financial data API -- token balances, top holders, historical data.",
    link: "https://github.com/openhive-network/wax/tree/develop/packages/wax-api-balance-tracker",
  },
];
---

<section id="ecosystem" aria-labelledby="ecosystem-title" class="mx-auto max-w-[1200px] px-6 py-32">
  <div class="reveal mb-16 text-center">
    <h2 id="ecosystem-title" class="text-h1 mb-4 font-bold tracking-tight text-text-primary" style="letter-spacing: -0.02em;">Part of the Hive Ecosystem</h2>
    <p class="mx-auto max-w-[600px] text-lg leading-relaxed text-text-secondary">WorkerBee integrates seamlessly with the official Hive TypeScript libraries.</p>
  </div>

  <div class="grid-eco">
    {ecosystemItems.map((item, i) => (
      <div class="reveal card-hover eco-card relative rounded-2xl border border-border-default bg-bg-surface p-8 text-center" style={`transition-delay: calc(${i} * 40ms);`}>
        <div class="relative mx-auto flex h-14 w-14 items-center justify-center">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" aria-hidden="true">
            <polygon points="28,2 51.8,15.5 51.8,42.5 28,56 4.2,42.5 4.2,15.5" stroke="var(--color-amber-border)" stroke-width="1.5" fill="none"/>
            <text x="28" y="34" text-anchor="middle" fill="#F59E0B" font-size="16" font-weight="700" font-family="Geist Mono, monospace">{item.letter}</text>
          </svg>
        </div>
        <h3 class="mt-4 font-[--font-code] text-2xl font-bold text-text-primary">{item.name}</h3>
        <p class="mt-1 font-[--font-code] text-sm text-amber-500">{item.pkg}</p>
        <p class="mt-3 text-base leading-relaxed text-text-secondary">{item.description}</p>
        <a href={item.link} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-amber-500 no-underline transition-colors duration-150">
          View on GitHub
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    ))}
  </div>
</section>
