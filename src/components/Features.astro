---
// Features section - 6 feature cards
const features = [
  {
    title: "Reactive API",
    description: "Observable-based pattern with no polling. Subscribe to blockchain events and react in real-time with RxJS-compatible streams.",
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>`,
  },
  {
    title: "25 Built-in Filters",
    description: "Pre-built event triggers covering blocks, accounts, finances, social content, and governance. Zero boilerplate.",
    icon: `<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>`,
  },
  {
    title: "7 Data Providers",
    description: "Automatically enrich your event data with account details, manabar stats, witness info, and market prices.",
    icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,
  },
  {
    title: "TypeScript-First",
    description: "Full type safety and autocomplete. Every filter and provider returns strongly-typed data -- no guessing.",
    icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><path d="M14 4l-4 16" stroke-width="1.5"/>`,
  },
  {
    title: "Custom Extensions",
    description: "Build your own filters and providers using the extensible API. Chain WAX extensions for custom data access.",
    icon: `<path d="M13.5 2H10.5C9.67 2 9 2.67 9 3.5V6H6.5C5.67 6 5 6.67 5 7.5V10H3.5C2.67 10 2 10.67 2 11.5V13.5C2 14.33 2.67 15 3.5 15H5V17.5C5 18.33 5.67 19 6.5 19H9V20.5C9 21.33 9.67 22 10.5 22H13.5C14.33 22 15 21.33 15 20.5V19H17.5C18.33 19 19 18.33 19 17.5V15H20.5C21.33 15 22 14.33 22 13.5V11.5C22 10.67 21.33 10 20.5 10H19V7.5C19 6.67 18.33 6 17.5 6H15V3.5C15 2.67 14.33 2 13.5 2Z"/>`,
  },
  {
    title: "Data Evaluation Context",
    description: "Shared cache across all filters. Zero duplicate blockchain queries. Access dynamic global properties from any filter.",
    icon: `<circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><line x1="12" y1="8" x2="5" y2="16"/><line x1="12" y1="8" x2="19" y2="16"/>`,
  },
];
---

<section id="features" aria-labelledby="features-title" class="mx-auto max-w-[1200px] px-6 py-32">
  <div class="reveal mb-16 text-center">
    <h2 id="features-title" class="text-h1 mb-4 font-bold tracking-tight text-text-primary" style="letter-spacing: -0.02em;">Built for Blockchain Developers</h2>
    <p class="mx-auto max-w-[600px] text-lg leading-relaxed text-text-secondary">Everything you need to observe, filter, and react to on-chain events.</p>
  </div>

  <div class="grid-features">
    {features.map((feature, i) => (
      <div class="reveal card-hover rounded-2xl border border-border-default bg-bg-surface p-8" style={`transition-delay: calc(${i} * 40ms);`}>
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-muted">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={feature.icon} />
        </div>
        <h3 class="mt-4 text-2xl font-semibold text-text-primary">{feature.title}</h3>
        <p class="mt-2 text-base leading-relaxed text-text-secondary">{feature.description}</p>
      </div>
    ))}
  </div>
</section>
