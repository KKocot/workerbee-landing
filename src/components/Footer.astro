---
const currentYear = new Date().getFullYear();
const VERSION = "v0.1";
const GITLAB_URL = "https://gitlab.syncad.com/hive/workerbee";
const GITLAB_RELEASES = `${GITLAB_URL}/-/releases`;
const MIT_LICENSE = `${GITLAB_URL}/-/blob/develop/LICENSE`;
const HIVE_URL = "https://hive.io";
---

<footer class="tmux-status" role="contentinfo">
  <div class="tmux-status__bar">
    <span class="tmux-status__segment"
      ><a
        href={GITLAB_RELEASES}
        class="tmux-status__link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`WorkerBee ${VERSION} — releases on GitLab`}
        >[workerbee {VERSION}]</a
      ></span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__segment"
      >&copy; {currentYear}</span
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={MIT_LICENSE}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="MIT License — opens in new tab"
      >MIT License</a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={HIVE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link"
      aria-label="Hive blockchain ecosystem — opens in new tab"
      >built for <span class="tmux-status__hive">hive</span></a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><a
      href={GITLAB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="tmux-status__link tmux-status__gitlab"
      aria-label="GitLab repository — opens in new tab"
      ><svg width="14" height="14" viewBox="0 0 380 380" fill="currentColor" aria-hidden="true"><path d="M282.83 170.73l-.27-.69-26.14-68.22a6.81 6.81 0 00-2.69-3.24 7 7 0 00-8 .43 7 7 0 00-2.32 3.52l-17.65 54h-71.47l-17.65-54a6.86 6.86 0 00-2.32-3.53 7 7 0 00-8-.43 6.87 6.87 0 00-2.69 3.24L97.44 170l-.26.69a48.54 48.54 0 0016.1 56.07l.09.07.24.17 39.82 29.82 19.7 14.91 12 9.06a8.07 8.07 0 009.76 0l12-9.06 19.7-14.91 40.06-30 .1-.08a48.56 48.56 0 0016.08-56.04z"/></svg></a
    ><span class="tmux-status__sep" aria-hidden="true">│</span><span
      class="tmux-status__dot"
      aria-label="Status: online">●</span
    >
  </div>
</footer>

<style>
  .tmux-status {
    background-color: var(--color-bg-surface);
    border-top: 1px solid color-mix(in srgb, var(--color-amber-500) 30%, transparent);
    font-family: var(--font-code);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .tmux-status__bar {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.5rem 1rem;
    min-height: 2rem;
  }

  .tmux-status__segment {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .tmux-status__sep {
    color: var(--color-text-muted);
    opacity: 0.4;
    padding-inline: 0.5rem;
    user-select: none;
  }

  .tmux-status__link {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color 150ms ease-out, text-shadow 150ms ease-out;
  }

  .tmux-status__link:hover,
  .tmux-status__link:focus-visible {
    color: var(--color-amber-500);
    text-shadow: 0 0 8px var(--color-amber-glow);
  }

  .tmux-status__link:focus-visible {
    outline: 2px solid var(--color-amber-500);
    outline-offset: 2px;
    border-radius: 0.25rem;
  }

  .tmux-status__gitlab {
    display: inline-flex;
    align-items: center;
  }

  .tmux-status__hive {
    color: #ff5070;
    font-weight: 600;
  }

  .tmux-status__dot {
    color: #4EBF71;
    font-size: 0.625rem;
    line-height: 1;
  }

  @media (max-width: 40rem) {
    .tmux-status__bar {
      padding: 0.5rem 0.75rem;
      justify-content: center;
    }
  }
</style>
