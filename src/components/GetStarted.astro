---
// Get Started section - install command with copy button + quickstart code
---

<section id="get-started" aria-labelledby="getstarted-title" class="relative px-6 py-32">
  <!-- Subtle amber gradient -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse at 50% 100%, rgba(245,158,11,0.04) 0%, transparent 50%);"></div>

  <div class="relative z-1 mx-auto max-w-[800px]">
    <div class="reveal mb-12 text-center">
      <h2 id="getstarted-title" class="text-h1 mb-4 font-bold tracking-tight text-text-primary" style="letter-spacing: -0.02em;">Start Observing in Minutes</h2>
      <p class="mx-auto max-w-[600px] text-lg leading-relaxed text-text-secondary">Install WorkerBee and write your first observer in 5 lines of code.</p>
    </div>

    <!-- Install command -->
    <div class="reveal mx-auto mb-8 max-w-[480px]">
      <div class="flex items-center justify-between rounded-xl border border-border-default bg-bg-code px-6 py-4">
        <div class="font-[--font-code] text-lg">
          <span class="text-text-muted">$ </span>
          <span class="text-amber-500">pnpm add @hiveio/workerbee</span>
        </div>
        <button
          id="copy-btn"
          aria-label="Copy install command"
          class="border-none bg-transparent p-1.5 text-text-muted transition-colors duration-150 cursor-pointer"
        >
          <span aria-live="polite" class="sr-only" id="copy-status"></span>
          <svg id="icon-clipboard" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg id="icon-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Quickstart code -->
    <figure role="region" aria-label="Code example: quickstart.ts" class="reveal">
      <div class="code-block">
        <div class="code-topbar">
          <span class="code-dot bg-[#EF4444]" aria-hidden="true"></span>
          <span class="code-dot bg-[#FBBF24]" aria-hidden="true"></span>
          <span class="code-dot bg-[#10B981]" aria-hidden="true"></span>
          <span class="mx-auto font-[--font-code] text-[0.8125rem] text-text-muted">quickstart.ts</span>
        </div>
        <pre class="m-0 overflow-x-auto px-6 py-5"><code class="font-[--font-code] text-[0.9375rem] leading-[1.7]"><span class="token-keyword">import</span> <span class="token-type">WorkerBee</span> <span class="token-keyword">from</span> <span class="token-string">"@hiveio/workerbee"</span><span class="token-punctuation">;</span>

<span class="token-keyword">const</span> <span class="token-property">bot</span> <span class="token-punctuation">=</span> <span class="token-keyword">new</span> <span class="token-type">WorkerBee</span><span class="token-punctuation">();</span>
<span class="token-keyword">await</span> <span class="token-property">bot</span><span class="token-punctuation">.</span><span class="token-function">start</span><span class="token-punctuation">();</span>

<span class="token-property">bot</span><span class="token-punctuation">.</span><span class="token-property">observe</span><span class="token-punctuation">.</span><span class="token-function">onBlock</span><span class="token-punctuation">().</span><span class="token-function">subscribe</span><span class="token-punctuation">({</span>
  <span class="token-function">next</span><span class="token-punctuation">:</span> <span class="token-punctuation">(</span><span class="token-property">data</span><span class="token-punctuation">)</span> <span class="token-keyword">=&gt;</span> <span class="token-property">console</span><span class="token-punctuation">.</span><span class="token-function">log</span><span class="token-punctuation">(</span><span class="token-string">"Block:"</span><span class="token-punctuation">,</span> <span class="token-property">data</span><span class="token-punctuation">.</span><span class="token-property">block</span><span class="token-punctuation">.</span><span class="token-property">number</span><span class="token-punctuation">),</span>
  <span class="token-property">error</span><span class="token-punctuation">:</span> <span class="token-property">console</span><span class="token-punctuation">.</span><span class="token-property">error</span>
<span class="token-punctuation">});</span></code></pre>
      </div>
      <figcaption class="sr-only">Quickstart code showing how to observe new blocks on the Hive blockchain.</figcaption>
    </figure>

    <!-- CTAs -->
    <div class="reveal mt-10 flex flex-wrap justify-center gap-4">
      <a href="https://gitlab.syncad.com/hive/workerbee#readme" target="_blank" rel="noopener noreferrer" class="btn-primary">Read the Docs</a>
      <a href="https://gitlab.syncad.com/hive/workerbee" target="_blank" rel="noopener noreferrer" class="btn-outline">
        <svg width="16" height="16" viewBox="0 0 380 380" fill="currentColor" aria-hidden="true"><path d="M282.83 170.73l-.27-.69-26.14-68.22a6.81 6.81 0 00-2.69-3.24 7 7 0 00-8 .43 7 7 0 00-2.32 3.52l-17.65 54h-71.47l-17.65-54a6.86 6.86 0 00-2.32-3.53 7 7 0 00-8-.43 6.87 6.87 0 00-2.69 3.24L97.44 170l-.26.69a48.54 48.54 0 0016.1 56.07l.09.07.24.17 39.82 29.82 19.7 14.91 12 9.06a8.07 8.07 0 009.76 0l12-9.06 19.7-14.91 40.06-30 .1-.08a48.56 48.56 0 0016.08-56.04z"/></svg>
        View Examples on GitLab
      </a>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById('copy-btn')!;
  const iconClipboard = document.getElementById('icon-clipboard')!;
  const iconCheck = document.getElementById('icon-check')!;
  const copyStatus = document.getElementById('copy-status')!;

  copyBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText('pnpm add @hiveio/workerbee');

    iconClipboard.classList.add('hidden');
    iconCheck.classList.remove('hidden');
    copyBtn.style.color = '#10B981';
    copyBtn.setAttribute('aria-label', 'Copied!');
    copyStatus.textContent = 'Command copied to clipboard';

    setTimeout(() => {
      iconClipboard.classList.remove('hidden');
      iconCheck.classList.add('hidden');
      copyBtn.style.color = '';
      copyBtn.setAttribute('aria-label', 'Copy install command');
      copyStatus.textContent = '';
    }, 2000);
  });
</script>
