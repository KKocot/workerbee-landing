---
// Hero section with honeycomb background and code preview
---

<section id="hero" aria-labelledby="hero-title" class="relative flex min-h-screen max-h-[900px] items-center overflow-hidden">
  <!-- Honeycomb background layers -->
  <div class="honeycomb-layer honeycomb-layer-1" aria-hidden="true"></div>
  <div class="honeycomb-layer honeycomb-layer-2" aria-hidden="true"></div>
  <div class="honeycomb-layer honeycomb-layer-3" aria-hidden="true"></div>
  <!-- Radial amber glow -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0" style="background: radial-gradient(circle at 50% 40%, rgba(245,158,11,0.08) 0%, transparent 60%);"></div>

  <div class="hero-grid relative z-1 mx-auto w-full max-w-[1400px] px-6 pt-24 pb-16">
    <!-- Text column -->
    <div>
      <!-- Overline -->
      <div class="mb-6 flex items-center gap-2">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="#F59E0B" aria-hidden="true"><polygon points="6,0 11.2,3 11.2,9 6,12 0.8,9 0.8,3"/></svg>
        <span class="text-xs font-semibold uppercase tracking-wider text-amber-500">Blockchain Observation Framework</span>
      </div>

      <!-- Headline -->
      <h1 id="hero-title" class="text-display mb-6 font-black leading-tight tracking-tight text-text-primary" style="letter-spacing: -0.02em;">
        Observe the Hive Blockchain in <span class="text-amber-500">Real-Time</span>
      </h1>

      <!-- Subtitle -->
      <p class="mb-8 max-w-[540px] text-lg leading-relaxed text-text-secondary">
        A reactive, event-driven TypeScript framework with 25 built-in filters and 7 data providers. Monitor accounts, finances, content, and governance with Observable-based API.
      </p>

      <!-- CTA Group -->
      <div class="mb-8 flex flex-wrap gap-4">
        <a href="#get-started" class="btn-primary">Get Started</a>
        <a href="https://github.com/openhive-network/workerbee" target="_blank" rel="noopener noreferrer" class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          View on GitHub
        </a>
      </div>

      <!-- Stats -->
      <dl class="stats-grid">
        <div class="flex items-center gap-2">
          <dt class="sr-only">Number of filters</dt>
          <dd class="text-sm"><span class="font-semibold text-text-primary">25</span> <span class="text-text-muted">Filters</span></dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="sr-only">Number of providers</dt>
          <dd class="text-sm"><span class="font-semibold text-text-primary">7</span> <span class="text-text-muted">Providers</span></dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="sr-only">Language</dt>
          <dd class="text-sm text-text-muted">TypeScript-First</dd>
        </div>
        <div class="flex items-center gap-2">
          <dt class="sr-only">API type</dt>
          <dd class="text-sm text-text-muted">Observable API</dd>
        </div>
      </dl>
    </div>

    <!-- Code preview -->
    <figure role="region" aria-label="Code example: whale-alert.ts" class="relative">
      <div class="code-block" style="box-shadow: inset 0 1px 0 rgba(245,158,11,0.1), 0 0 0 1px rgba(245,158,11,0.12), 0 0 24px var(--color-amber-glow);">
        <div class="code-topbar">
          <span class="code-dot bg-[#EF4444]" aria-hidden="true"></span>
          <span class="code-dot bg-[#FBBF24]" aria-hidden="true"></span>
          <span class="code-dot bg-[#10B981]" aria-hidden="true"></span>
          <span class="mx-auto font-[--font-code] text-[0.8125rem] text-text-muted">whale-alert.ts</span>
        </div>
        <pre class="m-0 overflow-x-auto px-6 py-5"><code class="font-[--font-code] text-[0.9375rem] leading-[1.7]"><span class="token-keyword">const</span> <span class="token-property">bot</span> <span class="token-punctuation">=</span> <span class="token-keyword">new</span> <span class="token-type">WorkerBee</span><span class="token-punctuation">();</span>
<span class="token-keyword">await</span> <span class="token-property">bot</span><span class="token-punctuation">.</span><span class="token-function">start</span><span class="token-punctuation">();</span>

<span class="token-property">bot</span><span class="token-punctuation">.</span><span class="token-property">observe</span>
  <span class="token-punctuation">.</span><span class="token-function">onWhaleAlert</span><span class="token-punctuation">(</span><span class="token-property">bot</span><span class="token-punctuation">.</span><span class="token-property">chain</span><span class="token-punctuation">.</span><span class="token-function">hiveCoins</span><span class="token-punctuation">(</span><span class="token-number">1000</span><span class="token-punctuation">))</span>
  <span class="token-punctuation">.</span><span class="token-function">subscribe</span><span class="token-punctuation">({</span>
    <span class="token-function">next</span><span class="token-punctuation">:</span> <span class="token-punctuation">(</span><span class="token-property">data</span><span class="token-punctuation">)</span> <span class="token-keyword">=&gt;</span> <span class="token-punctuation">{</span>
      <span class="token-property">console</span><span class="token-punctuation">.</span><span class="token-function">log</span><span class="token-punctuation">(</span><span class="token-string">"Whale:"</span><span class="token-punctuation">,</span> <span class="token-property">data</span><span class="token-punctuation">.</span><span class="token-property">whaleOperations</span><span class="token-punctuation">);</span>
    <span class="token-punctuation">}</span>
  <span class="token-punctuation">});</span></code></pre>
      </div>
      <figcaption class="sr-only">A code example showing how to set up a whale alert observer that triggers when transfers exceed 1000 HIVE.</figcaption>
    </figure>
  </div>
</section>
